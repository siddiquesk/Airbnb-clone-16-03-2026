<% layout("/layout/boilerplate") %>

<!-- HERO BANNER -->
<section
  class="relative w-screen h-[450px]">

  <!-- Background Image -->
  <img
    src="https://images.unsplash.com/photo-1500530855697-b586d89ba3ee"
    alt="About Wonderlust"
    class="absolute inset-0 w-full h-full object-cover"
  />

  <!-- Overlay -->
  <div class="absolute inset-0 bg-black/50"></div>

  <!-- Content -->
  <div class="relative h-full flex items-center">
    <div class="max-w-6xl mx-auto px-6 text-white">

      <h1 class="text-4xl md:text-5xl font-semibold mb-4">
        About Wonderlust
      </h1>

      <p class="text-lg text-gray-200 max-w-2xl">
        A modern platform connecting travelers with unique stays
        and helping property owners reach the right audience.
      </p>

    </div>
  </div>

</section>

<!-- PAGE CONTENT -->
<div class="min-h-screen w-full">

  <div class="max-w-6xl mx-auto px-6 py-20 space-y-20">

    <!-- SECTION 1 -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">

      <!-- CONTENT -->
      <div>
        <h2 class="text-3xl font-semibold text-gray-900 mb-4">
          Who We Are
        </h2>

        <p class="text-gray-700 leading-relaxed mb-4">
          Wonderlust is a travel listing platform inspired by the idea
          of simplifying how people discover, explore, and connect
          with unique stays across different locations.
        </p>

        <p class="text-gray-700 leading-relaxed">
          Whether you’re a traveler searching for the perfect stay
          or a property owner looking to showcase your space,
          Wonderlust makes the journey seamless and transparent.
        </p>
      </div>

      <!-- IMAGE -->
      <div class="rounded-lg overflow-hidden border border-gray-200">
        <img
          src="https://images.unsplash.com/photo-1505691938895-1758d7feb511"
          alt="Travel Experience"
          class="w-full h-[420px] object-cover"
        />
      </div>

    </div>

    <!-- SECTION 2 -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">

      <!-- IMAGE -->
      <div class="rounded-lg overflow-hidden border border-gray-200 order-last lg:order-first">
        <img
          src="https://images.unsplash.com/photo-1493809842364-78817add7ffb"
          alt="Our Mission"
          class="w-full h-[420px] object-cover"
        />
      </div>

      <!-- CONTENT -->
      <div>
        <h2 class="text-3xl font-semibold text-gray-900 mb-4">
          Our Mission
        </h2>

        <p class="text-gray-700 leading-relaxed mb-4">
          Our mission is to bridge the gap between travelers and
          property owners by providing a reliable, user-friendly,
          and modern listing experience.
        </p>

        <p class="text-gray-700 leading-relaxed">
          We focus on trust, simplicity, and accessibility—so users
          can explore stays confidently while hosts can manage
          listings with ease.
        </p>
      </div>

    </div>


<!-- EXPERIENCE / STATS -->
<div class="bg-white border border-gray-200 rounded-lg p-12">
  <h2 class="text-3xl font-semibold text-gray-900 text-center mb-10">
    Our Experience
  </h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 text-center">

    <div>
      <h3 class="text-4xl font-bold text-gray-900 mb-2">5K+</h3>
      <p class="text-gray-600">Happy Travelers</p>
    </div>

    <div>
      <h3 class="text-4xl font-bold text-gray-900 mb-2">2K+</h3>
      <p class="text-gray-600">Listed Properties</p>
    </div>

    <div>
      <h3 class="text-4xl font-bold text-gray-900 mb-2">100+</h3>
      <p class="text-gray-600">Cities Covered</p>
    </div>

    <div>
      <h3 class="text-4xl font-bold text-gray-900 mb-2">24/7</h3>
      <p class="text-gray-600">Customer Support</p>
    </div>

  </div>
</div>



<!-- OUR VALUES -->
<div class="bg-white border border-gray-200 rounded-lg p-12">
  <h2 class="text-3xl font-semibold text-gray-900 text-center mb-12">
    Why Choose Wonderlust?
  </h2>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

    <div class="border border-gray-200 rounded-lg p-6 text-center">
      <h3 class="text-xl font-medium mb-3">Trust & Transparency</h3>
      <p class="text-gray-600">
        We ensure verified listings and clear communication
        between travelers and property owners.
      </p>
    </div>

    <div class="border border-gray-200 rounded-lg p-6 text-center">
      <h3 class="text-xl font-medium mb-3">Easy Listings</h3>
      <p class="text-gray-600">
        Property owners can easily list, manage, and promote
        their villas, houses, or hotels.
      </p>
    </div>

    <div class="border border-gray-200 rounded-lg p-6 text-center">
      <h3 class="text-xl font-medium mb-3">Seamless Experience</h3>
      <p class="text-gray-600">
        From discovering stays to making decisions,
        everything is smooth and user-friendly.
      </p>
    </div>

  </div>
</div>

<!-- TESTIMONIALS -->
<div class="bg-white border border-gray-200 rounded-lg p-12">
  <h2 class="text-3xl font-semibold text-gray-900 text-center mb-12">
    What People Say About Us
  </h2>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

    <div class="border border-gray-200 rounded-lg p-6">
      <p class="text-gray-700 mb-4">
        “Wonderlust helped me find the perfect villa for my vacation.
        The experience was smooth and stress-free.”
      </p>
      <h4 class="font-medium text-gray-900">— Ayaan Khan</h4>
      <span class="text-sm text-gray-500">Traveler</span>
    </div>

    <div class="border border-gray-200 rounded-lg p-6">
      <p class="text-gray-700 mb-4">
        “Listing my property on Wonderlust was easy.
        I received great inquiries within days.”
      </p>
      <h4 class="font-medium text-gray-900">— Meera Sharma</h4>
      <span class="text-sm text-gray-500">Property Owner</span>
    </div>

    <div class="border border-gray-200 rounded-lg p-6">
      <p class="text-gray-700 mb-4">
        “A reliable platform that connects the right people.
        Highly recommended for travelers and hosts.”
      </p>
      <h4 class="font-medium text-gray-900">— Rohit Verma</h4>
      <span class="text-sm text-gray-500">Host</span>
    </div>

  </div>
</div>


<!-- CALL TO ACTION -->
<div class="bg-gray-900 text-white rounded-lg p-14 text-center">
  <h2 class="text-3xl font-semibold mb-4">
    Ready to Explore or List Your Property?
  </h2>
  <p class="text-gray-300 max-w-2xl mx-auto mb-6">
    Join Wonderlust today and discover amazing stays
    or showcase your property to travelers worldwide.
  </p>

  <a
    href="/listings"
    class="inline-block bg-white text-gray-900 px-6 py-3 rounded-md font-medium hover:bg-gray-100 transition">
    Explore Listings
  </a>
</div>
  </div>
</div>
<% layout("/layout/boilerplate") %>

<!-- FULL BODY GRADIENT -->
<div class="min-h-screen w-full flex  bg-gradient-to-br from-rose-100 via-orange-50 to-sky-100">

  <!-- CONTENT WRAPPER -->
  <div class="max-w-7xl mx-auto px-6 py-20">

    <!-- PAGE HEADER -->
    <div class="text-center mb-20">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900">
        Contact Wonderlust
      </h1>
      <p class="text-gray-600 mt-4 text-lg max-w-2xl mx-auto">
        We’d love to hear from you. Reach out to Wonderlust for travel support,
        listing help, or general queries.
      </p>
    </div>

    <!-- MAP + CONTACT -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 mb-24">

      <!-- MAP -->
      <div class="rounded-xl overflow-hidden ">
        <iframe
          class="w-full h-[450px]"
          src="https://www.google.com/maps?q=Delhi&output=embed"
          loading="lazy"
        ></iframe>
      </div>

      <!-- CONTACT CARD -->
      <div class="bg-white rounded-xl -2xl p-10 flex flex-col justify-center">

        <h2 class="text-3xl font-semibold text-gray-900 mb-8">
          Contact Details
        </h2>

        <div class="space-y-6 text-lg text-gray-700">

          <p>
            <span class="font-semibold text-gray-900">👤 Name</span><br />
            Sufiyan Siddique
          </p>

          <p>
            <span class="font-semibold text-gray-900">📍 Address</span><br />
            Shivaji Nagar, Govandi, Baigan Wadi<br />
            Mumbai, Maharashtra – 400043
          </p>

          <p>
            <span class="font-semibold text-gray-900">📞 Phone</span><br />
            9769285713
          </p>

          <p>
            <span class="font-semibold text-gray-900">✉️ Email</span><br />
            sufiyan9769285713@gmail.com
          </p>

        </div>

      </div>
    </div>

    <!-- ABOUT -->
    <div class="bg-white rounded-xl -2xl p-12 mb-24">
      <h2 class="text-3xl font-semibold text-gray-900 mb-6">
        About Wonderlust
      </h2>
      <p class="text-gray-700 text-lg leading-relaxed max-w-5xl">
        Wonderlust is a next-generation travel listing platform inspired by
        Airbnb. We help travelers find unique, affordable, and reliable stays
        while allowing hosts to manage listings with ease. Our focus is
        simplicity, transparency, and a delightful travel experience.
      </p>
    </div>

    <!-- FAQ -->
    <div class="bg-white rounded-xl -2xl p-12">
      <h2 class="text-3xl font-semibold text-gray-900 mb-10">
        Frequently Asked Questions
      </h2>

      <div class="space-y-6">

        <details class="group border border-gray-200 rounded-xl p-6">
          <summary class="flex justify-between items-center cursor-pointer text-lg font-medium text-gray-800">
            What is Wonderlust?
            <span class="transition group-open:rotate-180">⌄</span>
          </summary>
          <p class="mt-4 text-gray-600">
            Wonderlust is a travel listing platform where users can explore and
            manage stays across India and beyond.
          </p>
        </details>

        <details class="group border border-gray-200 rounded-xl p-6">
          <summary class="flex justify-between items-center cursor-pointer text-lg font-medium text-gray-800">
            Can I add my own property?
            <span class="transition group-open:rotate-180">⌄</span>
          </summary>
          <p class="mt-4 text-gray-600">
            Yes, you can easily add, edit, and delete your listings after
            registration.
          </p>
        </details>

        <details class="group border border-gray-200 rounded-2xl p-6">
          <summary class="flex justify-between items-center cursor-pointer text-lg font-medium text-gray-800">
            Is Wonderlust free to use?
            <span class="transition group-open:rotate-180">⌄</span>
          </summary>
          <p class="mt-4 text-gray-600">
            Yes, browsing and listing properties on Wonderlust is completely
            free.
          </p>
        </details>

        <details class="group border border-gray-200 rounded-xl p-6">
          <summary class="flex justify-between items-center cursor-pointer text-lg font-medium text-gray-800">
            Do you support bookings?
            <span class="transition group-open:rotate-180">⌄</span>
          </summary>
          <p class="mt-4 text-gray-600">
            Booking features are being developed and will be launched soon.
          </p>
        </details>

        <details class="group border border-gray-200 rounded-xl p-6">
          <summary class="flex justify-between items-center cursor-pointer text-lg font-medium text-gray-800">
            How can I contact support?
            <span class="transition group-open:rotate-180">⌄</span>
          </summary>
          <p class="mt-4 text-gray-600">
            You can reach us via phone or email listed above for any assistance.
          </p>
        </details>

      </div>
    </div>

  </div>
</div>
<% layout("/layout/boilerplate") %>

<div class="min-h-[60vh] flex items-center justify-center px-4 mb-12">
  <div class="max-w-lg w-full bg-white border border-red-200 rounded-xl shadow-lg p-6">

    <!-- ICON -->
    <div class="flex items-center mb-4">
      <div class="flex-shrink-0">
        <svg
          class="w-8 h-8 text-red-500"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 9v2m0 4h.01M5.07 19h13.86c1.54 0 2.5-1.67 1.73-3L13.73 4c-.77-1.33-2.69-1.33-3.46 0L3.34 16c-.77 1.33.19 3 1.73 3z"
          />
        </svg>
      </div>

      <h2 class="ml-3 text-xl font-semibold text-red-600">
        Error <%= status %>
      </h2>
    </div>

    <!-- MESSAGE -->
    <p class="text-gray-700 text-base mb-6">
      <%= message %>
    </p>

    <!-- ACTION -->
    <a
      href="/listings"
      class="inline-block w-full text-center bg-red-500 text-white py-2.5 rounded-lg font-medium hover:bg-red-600 transition"
    >
      Go back to Listings
    </a>

  </div>
</div>
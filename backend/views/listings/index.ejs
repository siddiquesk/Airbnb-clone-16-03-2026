<% layout("/layout/boilerplate") %>


  <!-- Page Heading -->
  <div class="text-center mb-0 md:mb-6 md:mt-4">
  <h1 class="text-3xl md:text-4xl font-semibold text-gray-900">
    Discover Beautiful Stays Around the World
  </h1>
  <p class="mt-3 text-gray-500 text-sm md:text-base max-w-2xl mx-auto">
    Browse unique homes, vacation rentals, and unforgettable places to stay — all in one place.
  </p>
</div>

<div class="max-w-7xl mx-auto px-4 py-10">
  <!-- Listings Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">

    <% for(let listing of allListings) { %>

      <!-- CARD -->
      <a href="/listings/<%= listing._id %>"
        class="group block rounded-xl overflow-hidden">

        <!-- Image Wrapper -->
        <div class="relative aspect-square overflow-hidden rounded-xl">

          <!-- Image -->
          <img
            src="<%= listing.image %>"
            alt="<%= listing.title %>"
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          />

          <!-- Overlay -->
          <div
            class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition duration-300">
          </div>

          <!-- Heart Icon -->
          <div
            class="absolute top-3 right-3 bg-white/90 backdrop-blur rounded-full p-2">
            <i class="fa-regular fa-heart text-gray-700"></i>
          </div>
        </div>

        <!-- Card Content -->
        <div class="pt-3 space-y-1">

          <!-- Location -->
          <h3 class="text-sm font-semibold">
            <%= listing.location %>, <%= listing.country %>
          </h3>

          <!-- Title -->
          <p class="text-sm text-gray-500 line-clamp-1">
            <%= listing.title %>
          </p>

          <!-- Description -->
          <p class="text-sm text-gray-500 line-clamp-2">
            <%= listing.description %>
          </p>

          <%
            const stayOptions = [
              "Night",
              "2 Days",
              "3 Days",
              "2 Nights",
              "4 Nights",
            ];
          %>

          <!-- Price -->
          <p class="text-sm font-semibold text-black pt-1">
            ₹ <%= listing.price %>
            <span class="font-normal text-gray-500">
              / <%= stayOptions[Math.floor(Math.random() * stayOptions.length)] %>
            </span>
          </p>

        </div>

      </a>

    <% } %>

  </div>

</div>
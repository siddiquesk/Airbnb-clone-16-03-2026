<% layout("/layout/boilerplate") %>

<body class="bg-white">

  <div class="max-w-4xl mx-auto px-4 md:px-6 py-10">

    <!-- PAGE TITLE -->
    <div class="mb-8">
      <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">
        Create a new listing
      </h1>
      <p class="text-gray-500 mt-1">
        Share details about your place for guests
      </p>
    </div>

    <!-- FORM -->
    <form action="/listings" method="POST" class="space-y-8">

      <!-- TITLE -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">
          Title
        </label>
        <input
          type="text"
          name="listing[title]"
          class="w-full border-b border-gray-300 focus:border-black outline-none py-2 text-gray-900"
          required
        />
      </div>

      <!-- DESCRIPTION -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">
          Description
        </label>
        <textarea
          name="listing[description]"
          rows="0"
          class="w-full border-b border-gray-300 focus:border-black outline-none py-2 text-gray-900 resize-none"
          required
        ></textarea>
      </div>

      <!-- IMAGE -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">
          Image URL
        </label>
        <input
          type="text"
          name="listing[image]"
          placeholder="https://example.com/image.jpg"
          class="w-full border-b border-gray-300 focus:border-black outline-none py-2 text-gray-900"
          required
        />
      </div>

      <!-- PRICE -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">
          Price (per night)
        </label>
        <input
          type="number"
          name="listing[price]"
        
          class="w-full border-b border-gray-300 focus:border-black outline-none py-2 text-gray-900"
          required
        />
      </div>

      <!-- LOCATION -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">
          Location
        </label>
        <input
          type="text"
          name="listing[location]"
         
          class="w-full border-b border-gray-300 focus:border-black outline-none py-2 text-gray-900"
          required
        />
      </div>

      <!-- COUNTRY -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">
          Country
        </label>
        <input
          type="text"
          name="listing[country]"
          class="w-full border-b border-gray-300 focus:border-black outline-none py-2 text-gray-900"
          required
        />
      </div>

      <!-- ACTION -->
      <div class="pt-6">
        <button
          type="submit"
          class="bg-[#FF385C] text-white cursor-pointer px-10 py-3 rounded-lg font-medium hover:bg-[#e0314f] transition"
        >
          Create listing
        </button>
      </div>

    </form>

  </div>

</body>
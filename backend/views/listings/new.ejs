<% layout("/layout/boilerplate") %>

<div class="max-w-4xl mx-auto px-4 md:px-6 py-10">

  <!-- PAGE TITLE -->
  <div class="mb-8">
    <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">
      Create a new listing
    </h1>
    <p class="text-gray-500 mt-1">
      Share details about your place for guests
    </p>
  </div>

  <!-- FORM -->
  <form id="listingForm" action="/listings" method="POST" class="space-y-8" enctype="multipart/form-data">

    <!-- TITLE -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Title</label>
      <input
        id="title"
        type="text"
        name="listing[title]"
        class="w-full border-b border-gray-300 focus:border-black outline-none py-2"
      />
      <p id="titleError" class="error-text"></p>
    </div>

    <!-- DESCRIPTION -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Description</label>
      <textarea
        id="description"
        name="listing[description]"
        rows="3"
        class="w-full border-b border-gray-300 focus:border-black outline-none py-2 resize-none"
      ></textarea>
      <p id="descriptionError" class="error-text"></p>
    </div>

    <!-- IMAGE -->
    <!-- <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Image URL</label>
      <input
        id="image"
        type="text"
        name="listing[image]"
        placeholder="https://example.com/image.jpg"
        class="w-full border-b border-gray-300 focus:border-black outline-none py-2"
      />
      <p id="imageError" class="error-text"></p>
    </div> -->
 <!-- IMAGE -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Upload Your Image</label>
      <input
        id="image"
        type="file"
        name="listing[image]"
        placeholder="Upload Your Image"
        class="w-full border-b border-gray-300 focus:border-black outline-none py-2"
      />
      <p id="imageError" class="error-text"></p>
    </div>
    <!-- PRICE -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Price (per night)</label>
      <input
        id="price"
        type="number"
        name="listing[price]"
        class="w-full border-b border-gray-300 focus:border-black outline-none py-2"
      />
      <p id="priceError" class="error-text"></p>
    </div>

    <!-- LOCATION -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Location</label>
      <input
        id="location"
        type="text"
        name="listing[location]"
        class="w-full border-b border-gray-300 focus:border-black outline-none py-2"
      />
      <p id="locationError" class="error-text"></p>
    </div>

    <!-- COUNTRY -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Country</label>
      <input
        id="country"
        type="text"
        name="listing[country]"
        class="w-full border-b border-gray-300 focus:border-black outline-none py-2"
      />
      <p id="countryError" class="error-text"></p>
    </div>

    <!-- BUTTON -->
    <div class="pt-6">
      <button
        type="submit"
        class="bg-[#FF385C] text-white cursor-pointer px-10 py-3 rounded-lg font-medium hover:bg-[#e0314f] transition"
      >
        Create listing
      </button>
    </div>

  </form>
</div>

<!-- VALIDATION SCRIPT -->



<% layout("/layout/boilerplate") %>

<div class="min-h-screen flex items-center justify-center bg-gray-50 px-6">

  <div class="bg-white border border-gray-200 rounded-lg p-10 max-w-md w-full text-center">

    <!-- Icon -->
    <div class="flex justify-center mb-6">
      <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center text-green-600 text-3xl">
        ✓
      </div>
    </div>

    <!-- Title -->
    <h1 class="text-2xl font-semibold text-gray-900 mb-3">
      Thank You!
    </h1>

    <!-- Message -->
    <p class="text-gray-600 mb-6">
      Your message has been successfully sent.  
      Our team will get back to you shortly.
    </p>

    <!-- Actions -->
    <div class="flex flex-col gap-3">
      <a
        href="/listings"
        class="inline-block bg-gray-900 text-white px-6 py-2.5 rounded-md text-sm font-medium hover:bg-gray-800 transition">
        Back to Home
      </a>

      <a
        href="/contact"
        class="inline-block text-gray-600 text-sm hover:underline">
        Send another message
      </a>
    </div>

  </div>

</div>
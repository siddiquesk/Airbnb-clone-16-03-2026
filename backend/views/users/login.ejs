<% layout("/layout/boilerplate") %>
<% if (success && success.length) { %>
  <div class="mb-4 mx-auto flex md:mt-16 mt-10 max-w-md items-center justify-between rounded-lg border border-green-300 bg-green-50 px-4 py-3 text-green-800">
    <span class="text-center">✅ <%= success[0] %></span>
    <button onclick="this.parentElement.remove()" class="text-green-700 hover:text-green-900 cursor-pointer">
      ✕
    </button>
  </div>
<% } %>
<% if (error && error.length) { %>
  <div class="mb-4 mx-auto flex md:mt-16 mt-10 max-w-md items-center justify-between rounded-lg border border-red-300 bg-red-50 px-4 py-3 text-red-800">
    <span>❌ <%= error[0] %></span>
    <button
      type="button"
      onclick="this.parentElement.remove()"
      class="cursor-pointer text-red-700 hover:text-red-900"
    >
      ✕
    </button>
  </div>
<% } %>
<div class="min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-md bg-white rounded-xl shadow-lg p-8 mb-10">
    
    <h2 class="text-2xl font-bold text-center text-gray-800 mb-6">
      Login on Wonderlust
    </h2>

    <form action="/login" method="POST" class="space-y-5">

      <!-- Username -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Username
        </label>
        <input
          type="text"
          name="username"
          required
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
          placeholder="Enter username"
        />
      </div>
      <!-- Password -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Password
        </label>
        <input
          type="password"
          name="password"
          required
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
          placeholder="Enter password"
        />
      </div>

      <!-- Button -->
    <button
  type="submit"
  class="w-full bg-blue-600 cursor-pointer text-white py-2 rounded-lg font-semibold hover:bg-blue-700 transition duration-300"
>
  Login
</button>

<p class="text-center text-sm text-gray-600 mt-4">
  Don’t have an account?
  <a
    href="/signup"
    class="text-blue-600 font-medium hover:underline hover:text-blue-700"
  >
    Sign up
  </a>
</p>

    </form>
  </div>
</div>